# PostgreSQL — local Docker: see docker-compose.yml, or use Neon / Supabase on Vercel.
DATABASE_URL="postgresql://garage:garage@localhost:5432/garage?schema=public"
AUTOTRADER_API_URL="https://api-sandbox.autotrader.co.uk"
AUTOTRADER_PARTNER_KEY="your-autotrader-partner-key"
AUTOTRADER_PARTNER_SECRET="your-autotrader-partner-secret"
AUTOTRADER_WEBHOOK_SECRET="your-autotrader-webhook-secret"
AUTOTRADER_ADVERTISER_ID=""

# Google Analytics Data API (dashboard analytics page)
# Property ID: GA4 → Admin → Property settings (numeric, not G-XXXX)
GA_PROPERTY_ID=your-ga4-property-id
GA_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
